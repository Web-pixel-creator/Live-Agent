FROM node:22-bookworm-slim

WORKDIR /app

COPY package.json package-lock.json tsconfig.base.json ./
COPY apps ./apps
COPY agents ./agents
COPY shared ./shared

RUN npm ci --include=dev --no-audit --no-fund

ENV NODE_ENV=production
EXPOSE 8080

CMD ["node", "--import", "tsx", "apps/realtime-gateway/src/index.ts"]

