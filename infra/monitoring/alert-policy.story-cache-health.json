{
  "displayName": "MLA Story Cache Health",
  "documentation": {
    "content": "Story cache signal disappeared or cache churn became abnormally high. Inspect storyteller cache policy/versioning and cache limits.",
    "mimeType": "text/markdown"
  },
  "combiner": "OR",
  "enabled": true,
  "notificationChannels": __NOTIFICATION_CHANNELS__,
  "alertStrategy": {
    "autoClose": "1800s"
  },
  "conditions": [
    {
      "displayName": "Story cache metric rate <= 0",
      "conditionThreshold": {
        "filter": "resource.type=\"global\" AND metric.type=\"logging.googleapis.com/user/mla_analytics_metric_value\"",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM"
          }
        ],
        "comparison": "COMPARISON_LT",
        "thresholdValue": 0.0001,
        "duration": "300s",
        "trigger": {
          "count": 1
        }
      }
    },
    {
      "displayName": "Story cache metric rate > 10/sec",
      "conditionThreshold": {
        "filter": "resource.type=\"global\" AND metric.type=\"logging.googleapis.com/user/mla_analytics_metric_value\"",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM"
          }
        ],
        "comparison": "COMPARISON_GT",
        "thresholdValue": 10,
        "duration": "300s",
        "trigger": {
          "count": 1
        }
      }
    }
  ]
}
