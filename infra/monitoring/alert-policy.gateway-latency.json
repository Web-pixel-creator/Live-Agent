{
  "displayName": "MLA Gateway Telemetry Rate Missing",
  "documentation": {
    "content": "Gateway-side analytics telemetry disappeared or dropped below the expected baseline. Check realtime-gateway health, upstream Live API status, and reconnect/failover diagnostics.",
    "mimeType": "text/markdown"
  },
  "combiner": "OR",
  "enabled": true,
  "notificationChannels": __NOTIFICATION_CHANNELS__,
  "alertStrategy": {
    "autoClose": "1800s"
  },
  "conditions": [
    {
      "displayName": "Analytics metric rate <= 0",
      "conditionThreshold": {
        "filter": "resource.type=\"global\" AND metric.type=\"logging.googleapis.com/user/mla_analytics_metric_value\"",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM"
          }
        ],
        "comparison": "COMPARISON_LT",
        "thresholdValue": 0.0001,
        "duration": "300s",
        "trigger": {
          "count": 1
        }
      }
    }
  ]
}
